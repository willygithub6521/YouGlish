{
  "name": "backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext ts --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts --fix",
    "clean": "rm -rf dist node_modules",
    "db:migrate": "tsx src/database/migrate.ts migrate",
    "db:migrate:status": "tsx src/database/migrate.ts status",
    "db:seed": "tsx src/database/seed.ts seed",
    "db:seed:clear": "tsx src/database/seed.ts clear",
    "db:seed:reset": "tsx src/database/seed.ts reset",
    "es:setup": "tsx src/elasticsearch/cli.ts setup",
    "es:health": "tsx src/elasticsearch/cli.ts health",
    "es:status": "tsx src/elasticsearch/cli.ts status",
    "es:reset": "tsx src/elasticsearch/cli.ts reset",
    "es:test": "tsx src/elasticsearch/cli.ts test"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.11.0",
    "axios": "^1.6.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "googleapis": "^171.4.0",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "pg": "^8.11.3",
    "redis": "^4.6.10",
    "winston": "^3.11.0",
    "youtube-transcript": "^1.3.0"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.9.0",
    "@types/pg": "^8.10.9",
    "@types/supertest": "^2.0.16",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "eslint": "^8.53.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "tsx": "^4.1.4",
    "typescript": "^5.2.2"
  }
}
