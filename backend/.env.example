# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/youtube_pronunciation
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=youtube_pronunciation
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Elasticsearch Configuration
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_PREFIX=youtube_pronunciation

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# YouTube API Configuration
YOUTUBE_API_KEY=your_youtube_api_key_here
YOUTUBE_API_BASE_URL=https://www.googleapis.com/youtube/v3

# Server Configuration
PORT=3001
NODE_ENV=development

# CORS Configuration
FRONTEND_URL=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Cache Configuration
CACHE_TTL_SEARCH_RESULTS=3600
CACHE_TTL_VIDEO_METADATA=86400
CACHE_TTL_SUBTITLES=86400

# Logging
LOG_LEVEL=info
LOG_FILE=logs/app.log